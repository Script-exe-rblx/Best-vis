-- ── CONTENT UPDATE ────────────────────────────────────

local navBtns = {}

local function updateContent(idx)
    local s = SCRIPTS[idx]
    IconLbl.Text    = s.icon
    ContentName.Text = s.name
    ContentDesc.Text = s.desc
    selectedCode    = s.code
    selectedIndex   = idx
    -- Update nav highlight
    for i, btn in ipairs(navBtns) do
        if i == idx then
            TweenService:Create(btn, TweenInfo.new(0.15), {
                BackgroundColor3       = Color3.fromRGB(0, 130, 220),
                BackgroundTransparency = 0.22,
            }):Play()
            btn:FindFirstChild("NavStroke").Transparency = 0
        else
            TweenService:Create(btn, TweenInfo.new(0.15), {
                BackgroundColor3       = Color3.fromRGB(0, 80, 160),
                BackgroundTransparency = 0.88,
            }):Play()
            btn:FindFirstChild("NavStroke").Transparency = 0.7
        end
    end
end

