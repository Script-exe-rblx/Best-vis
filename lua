    valueBox.Position = UDim2.new(0.65, 0, 0, 0)
    valueBox.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
    valueBox.BorderSizePixel = 0
    valueBox.Font = Enum.Font.GothamSemibold
